# Gemini API key — get a free key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIza...

# Gemini model for AI Fill. Free-tier rate limits (RPM = requests per minute):
#   gemini-2.0-flash-lite   30 RPM  — default; fast, good specs recall, best for frequent use
#   gemini-2.0-flash        15 RPM  — stronger reasoning, useful for obscure trims
#   gemini-2.5-flash        10 RPM  — most capable flash model; slower, lower free quota
#   gemini-2.5-pro           2 RPM  — overkill for specs; hits quota immediately on free tier
VITE_GEMINI_MODEL=gemini-2.0-flash-lite
